{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {

        "rgname": {
            "value": "$(rgName)"
        },
        "sharedrgName":{
            "value": "$(sharedrgName)"
        },
        "vnetname": {
            "value": "$(vnet)"
        },
        "addressPrefix": {
            "value": "$(addressPrefix)"
        },
        "devcentername": {
            "value": "$(devcenter)"
        },
        "catalogName":{
            "value": "catalog"
        },
        "catalogRepoUri":{
            "value": "https://github.com/avl-sdv/DevOpsPilot.SiL.Workflows.git"
        },
        "catalogTasksName":{
            "value": "CustomizationTasksCatalog"
        },
        "catalogTasksRepoUri":{
            "value": "https://github.com/avl-sdv/DevOpsPilot.DevBox.CustomizationTasksCatalog.git"
        },
        "environmentName":{
            "value": "sandbox"
        },
        "law":{
            "value": "$(law)"
        },
        "location": {
            "value": "westeurope"
        },
        "tags": {
            "value": {
                "infra": "customer"
            }
        },    
        "catalogRepoPat": {
            "value": "$(catalogRepoPat)"
            
        },
        "privateDnsZoneName": {
            "value": "avl.lnk"
          },
        "privateLinkServiceId": {
            "value": "$(privateLinkServiceAlias)"
        },
        "privateEndpointName":{
            "value": "$(privateEndpointName_license_server)"
        },
        "privateDnsRecordName":{
            "value": "license"
        }

    }
}
